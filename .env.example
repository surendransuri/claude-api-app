# Azure AI Foundry
AZURE_FOUNDRY_BASE_URL=https://your-resource.services.ai.azure.com/models
AZURE_FOUNDRY_API_KEY=your-api-key-here
AZURE_FOUNDRY_MODEL=claude-sonnet-4-6

# Azure Cosmos DB
COSMOS_DB_URL=https://your-account.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-db-key
COSMOS_DB_DATABASE=poc-grace

# Auth
JWT_SECRET=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Demo user (change these)
DEMO_USERNAME=admin
DEMO_EMAIL=admin@nexchat.local
DEMO_PASSWORD=nexchat123

# App
APP_NAME=NexChat
FRONTEND_URL=http://localhost:3000
